{
	"name": "nestjs-ai-toolkit",
	"version": "0.1.0",
	"description": "NestJS module for bridging Vercel AI SDK tools",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"format": "prettier --write \"src/**/*.ts\"",
		"test": "jest --config ./tests/jest.config.js --runInBand",
		"test:dev": "jest --config ./tests/jest.config.js --runInBand --watch",
		"prepare": "husky"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/idbenami/nestjs-ai-toolkit.git"
	},
	"bugs": {
		"url": "https://github.com/idbenami/nestjs-ai-toolkit/issues"
	},
	"homepage": "https://github.com/idbenami/nestjs-ai-toolkit#readme",
	"keywords": [
		"nestjs",
		"ai",
		"ai-sdk",
		"tools"
	],
	"author": {
		"name": "idbenami",
		"url": "https://github.com/idbenami"
	},
	"license": "MIT",
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@nestjs/common": "11.1.18",
		"@nestjs/core": "11.1.18",
		"@nestjs/testing": "11.1.18",
		"@types/jest": "29.5.14",
		"husky": "^9.1.7",
		"jest": "29.7.0",
		"prettier": "3.8.1",
		"ts-jest": "29.3.2",
		"tslib": "2.8.1",
		"typescript": "5.8.3"
	},
	"peerDependencies": {
		"@nestjs/common": "^10.0.0 || ^11.0.0",
		"@nestjs/core": "^10.0.0 || ^11.0.0",
		"ai": "^6.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"release": {
		"branches": [
			"main"
		],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			"@semantic-release/npm",
			"@semantic-release/github"
		]
	}
}
